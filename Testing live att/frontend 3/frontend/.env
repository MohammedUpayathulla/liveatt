# Live Attendance — Frontend environment variables
# All VITE_ prefixed variables are bundled into the browser by Vite.
# Restart the dev server after changing these.

# Dev server port (the browser opens this)
VITE_DEV_PORT=3000

# Backend server port (Vite proxy target)
VITE_BACKEND_PORT=5005

# Backend host for Vite proxy (server-to-server, stays HTTP)
VITE_BACKEND_HOST=172.16.1.157

# API base URL — empty = use same-origin /api through Vite HTTPS proxy
VITE_API_BASE_URL=

# Socket.IO connection URL — empty = connect to same origin through Vite HTTPS proxy
VITE_SOCKET_URL=

# Socket.IO reconnection settings
VITE_SOCKET_RECONNECT_ATTEMPTS=10
VITE_SOCKET_RECONNECT_DELAY_MS=1000
VITE_SOCKET_RECONNECT_DELAY_MAX_MS=5000
VITE_SOCKET_TIMEOUT_MS=5000

# API request timeout (ms)
VITE_API_TIMEOUT_MS=10000

# API result cache TTL (ms)
VITE_CACHE_TTL_MS=5000